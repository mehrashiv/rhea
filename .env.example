# Public InsForge backend URL and anon key — safe to expose to the browser.
# Get these from your InsForge project (see README "Get started").
NEXT_PUBLIC_INSFORGE_URL=https://your-app.region.insforge.app
NEXT_PUBLIC_INSFORGE_ANON_KEY=

# Admin API key — used only by the InsForge MCP server / CLI for local
# tooling (migrations, schema, storage). Never expose this in the browser
# and never set it on Vercel.
INSFORGE_API_KEY=
